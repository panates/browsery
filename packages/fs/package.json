{
  "name": "@browsery/fs",
  "version": "0.5.1-r2",
  "description": "Browser compatible NodeJS fs module",
  "author": "Panates",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "rollup-plugin-command": "^1.1.3",
    "@rollup-extras/plugin-clean": "^2.0.0"
  },
  "peerDependencies": {},
  "scripts": {
    "prebuild": "npm run clean && npm run lint",
    "build": "rollup -c rollup.config.mjs",
    "clean": "rimraf build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --max-warnings=0 --fix",
    "format": "prettier . --write --log-level=warn"
  },
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "exports": {
    ".": {
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panates/browsery.git",
    "directory": "packages/fs"
  },
  "keywords": [
    "fs",
    "browser",
    "browsery",
    "browserify"
  ],
  "buildDir": "./build",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
