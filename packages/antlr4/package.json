{
  "name": "@browsery/antlr4",
  "version": "4.13.3-r5",
  "description": "Browser compatible antlr4 module",
  "author": "Panates",
  "license": "MIT",
  "scripts": {
    "prebuild": "npm run clean && npm run lint",
    "build": "node build.mjs",
    "clean": "rimraf build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --max-warnings=0 --fix",
    "format": "prettier . --write --log-level=warn"
  },
  "devDependencies": {
    "antlr4": "^4.13.2"
  },
  "type": "module",
  "main": "./index.node.js",
  "module": "./index.node.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "browser": "./index.web.js",
      "default": "./index.node.js"
    },
    "./package.json": "./package.json"
  },

  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panates/browsery.git",
    "directory": "packages/antlr4"
  },
  "keywords": [
    "antlr4",
    "browser",
    "browsery",
    "browserify"
  ],
  "buildDir": "./build",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
