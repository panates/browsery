{
  "name": "@browsery/highland",
  "version": "2.13.6-r5",
  "description": "Browser compatible highland module",
  "author": "Panates",
  "license": "MIT",
  "scripts": {
    "prebuild": "npm run clean && npm run lint",
    "build": "rollup -c rollup.config.mjs",
    "clean": "rimraf ../../build/highland",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --max-warnings=0 --fix",
    "format": "prettier . --write --log-level=warn"
  },
  "dependencies": {
    "@browsery/stream": "^4.7.0-r2",
    "@browsery/util": "^0.12.6-r3",
    "events": "^3.3.0",
    "process": "^0.11.10",
    "string_decoder": "^1.3.0",
    "util-deprecate": "^1.0.2"
  },
  "devDependencies": {
    "@types/highland": "^2.13.0",
    "@rollup-extras/plugin-clean": "^2.0.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-inject": "^5.0.5",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-strip": "^3.0.4",
    "ansi-colors": "^4.1.3",
    "highland": "^2.13.5",
    "rollup-plugin-command": "^1.1.3",
    "rollup-plugin-filesize": "^10.0.0"
  },
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panates/browsery.git",
    "directory": "packages/highland"
  },
  "keywords": [
    "highland",
    "browser",
    "browsery",
    "browserify"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
