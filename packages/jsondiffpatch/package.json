{
  "name": "@browsery/jsondiffpatch",
  "version": "0.7.3",
  "description": "Browser compatible jsondiffpatch",
  "author": "Panates",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panates/browsery.git",
    "directory": "packages/jsondiffpatchs"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-inject": "^5.0.5",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-strip": "^3.0.4",
    "@rollup-extras/plugin-clean": "^2.0.0",
    "ansi-colors": "^4.1.3",
    "fast-glob": "^3.3.3",
    "jsondiffpatch": "^0.7.3",
    "rollup-plugin-command": "^1.1.3",
    "rollup-plugin-filesize": "^10.0.0"
  },
  "scripts": {
    "prebuild": "npm run clean && npm run lint",
    "build": "rollup -c rollup.config.mjs",
    "clean": "rimraf build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --max-warnings=0 --fix",
    "format": "prettier . --write --log-level=warn"
  },
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./with-text-diffs": {
      "types": "./with-text-diffs.d.ts",
      "default": "./with-text-diffs.js"
    },
    "./formatters/*": {
      "types": "./formatters/*.d.ts",
      "default": "./formatters/*.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "keywords": [
    "jsondiffpatch",
    "jsonpatch",
    "json",
    "diff",
    "patch"
  ],
  "buildDir": "./build",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
